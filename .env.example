# Roboflow legacy baseline
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL_ID=

# Video input
VIDEO_SOURCE=./datasets/sample_videos/test.mov

# Detector backend
# Options: roboflow, yolo
DETECTOR_BACKEND=yolo

# Local YOLO
YOLO_MODEL_PATH=./pc_app/models/local/yolo26n.pt
YOLO_IMGSZ=640
YOLO_VERBOSE=false

# Detection threshold
CONFIDENCE_THRESHOLD=0.3

# Runtime display/output
SHOW_WINDOW=false
SAVE_OUTPUT_VIDEO=false
OUTPUT_VIDEO_PATH=./outputs/benchmarks/yolo26n_pt_pc/annotated_full_pipeline.mp4

# Density and scheduler
DENSITY_SMOOTHING_ALPHA=0.30
BASE_GREEN_TIME=20
MIN_GREEN_TIME=10
MAX_GREEN_TIME=45
YELLOW_TIME=3
ALL_RED_TIME=1
DENSITY_EPSILON=1e-6

# Benchmark
BENCHMARK_MAX_FRAMES=300

# ---------------------------------------------------------------------
# Phase 8: UART / MCU communication
# ---------------------------------------------------------------------

# Enable UART only when an MCU is connected.
ENABLE_UART=false

# Arduino Uno example on macOS:
UART_PORT=/dev/cu.usbmodem141011

# ESP32 examples:
# UART_PORT=/dev/cu.usbserial-XXXX
# UART_PORT=/dev/cu.wchusbserialXXXX
# UART_PORT=/dev/cu.SLAB_USBtoUART

# Linux / Raspberry Pi examples:
# UART_PORT=/dev/ttyUSB0
# UART_PORT=/dev/ttyACM0

UART_BAUD=115200
UART_SEND_INTERVAL_FRAMES=30
UART_ACK_TIMEOUT=2.0
UART_MIN_GREEN_CHANGE=1

# Log path for runtime metrics 
RUNTIME_LOG_DIR=./outputs/pipeline_runs/yolo26n_runtime_baseline/logs
